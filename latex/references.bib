@article{
    sano2025wavemamba,
    author = {Akane Sano  and Peikun Guo },
    title = {{WaveMamba}: Efficient Full-Night Sleep Staging via Wavelets and State Space Models},
    journal = {TechRxiv},
    volume = {2025},
    number = {0625},
    pages = {},
    year = {2025},
    doi = {10.36227/techrxiv.175086730.05160218/v1},
    URL = {https://www.techrxiv.org/doi/abs/10.36227/techrxiv.175086730.05160218/v1},
    eprint = {https://www.techrxiv.org/doi/pdf/10.36227/techrxiv.175086730.05160218/v1},
    abstract = {Automated sleep staging supports clinical diagnosis by classifying polysomnography recordings into sleep stages, but current methods often struggle with challenging transitional stages. Sleep exhibits complex multi-scale physiological patterns: distinct frequencyspecific neural oscillations (delta waves in deep sleep, spindles in N2, alpha rhythms during wake transitions) that evolve across natural sleep cycles. We introduce WaveMamba, which captures these patterns through discrete wavelet transform decomposition into physiologically meaningful frequency bands, each processed by dedicated Mamba branches. Cross-attention fusion dynamically integrates frequency-specific features based on sleep context. Mamba's selective state-space mechanism enables efficient processing of complete sleep recordings with linear computational scaling. Evaluated on Sleep-EDF and SHHS datasets using single-channel EEG, our method achieves 86.0\% accuracy and 78.6\% macro-F1 on Sleep-EDF78, with notable improvements in N1 detection. This work establishes a framework for capturing the multi-scale nature of physiological signals in automated sleep analysis. The full codebase will be open-sourced upon acceptance.}
}

